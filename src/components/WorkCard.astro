---
import { Picture } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { entryAsset } from '../lib/images';

interface Props {
  entry: CollectionEntry<'works'> | CollectionEntry<'commissions'>;
  base: 'works' | 'commissions';
}
const { entry, base } = Astro.props;
const { data } = entry;
const cover = entryAsset(entry, data.cover);
const href = `/${base}/${entry.id}`;
const meta = 'client' in data ? `${data.client} · ${data.year}` : `${data.year}`;
---

<a class="card" href={href}>
  <div class="thumb">
    <Picture
      src={cover}
      formats={['avif', 'webp']}
      alt={data.coverAlt}
      widths={[320, 480, 640, 800]}
      sizes="(min-width: 1000px) 360px, (min-width: 600px) 45vw, 90vw"
    />
  </div>
  <div class="card-body">
    <h3>{data.title}</h3>
    <p class="meta muted">{meta}</p>
    <p class="desc">{data.shortDescription}</p>
  </div>
</a>

<style>
  .card {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .thumb {
    aspect-ratio: 3 / 2;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--line);
    background: var(--bg-elev);
  }
  .thumb :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .card:hover .thumb :global(img) {
    transform: scale(1.04);
  }
  .card-body {
    padding-top: 0.85rem;
  }
  h3 {
    font-size: var(--step-1);
  }
  .meta {
    font-size: var(--step--1);
    margin-top: 0.15rem;
  }
  .desc {
    margin-top: 0.45rem;
    color: var(--fg-dim);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
