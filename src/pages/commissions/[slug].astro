---
import { getCollection, getEntries, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Gallery from '../../components/Gallery.astro';
import WorkGrid from '../../components/WorkGrid.astro';
import { entryAsset } from '../../lib/images';

export async function getStaticPaths() {
  const commissions = (await getCollection('commissions')).filter((c) =>
    import.meta.env.PROD ? !c.data.draft : true,
  );
  return commissions.map((commission) => ({
    params: { slug: commission.id },
    props: { commission },
  }));
}

const { commission } = Astro.props;
const { data } = commission;
const cover = entryAsset(commission, data.cover);
const { Content } = await render(commission);
const relatedWorks = data.relevantWorks.length
  ? (await getEntries(data.relevantWorks)).filter(Boolean)
  : [];
---

<BaseLayout title={data.title} description={data.shortDescription} image={cover} article>
  <article>
    <header class="container detail-head">
      <p class="eyebrow">Commission · {data.client} · {data.year}</p>
      <h1>{data.title}</h1>
      <p class="lead dim">{data.shortDescription}</p>
    </header>

    <div class="container cover-wrap">
      <Image
        src={cover}
        alt={data.coverAlt}
        widths={[640, 1000, 1400, 1920]}
        sizes="(min-width: 1200px) 1100px, 100vw"
      />
    </div>

    <div class="container body-wrap">
      <div class="prose"><Content /></div>
    </div>

    <div class="container gallery-wrap">
      <Gallery entry={commission} />
    </div>

    {
      relatedWorks.length > 0 && (
        <section class="section container related">
          <h2>Related works</h2>
          <WorkGrid items={relatedWorks} base="works" />
        </section>
      )
    }
  </article>
</BaseLayout>

<style>
  .detail-head {
    padding-top: var(--section-y);
  }
  .lead {
    max-width: 60ch;
    margin-top: 0.6rem;
    font-size: var(--step-1);
  }
  .cover-wrap {
    margin-top: var(--gap);
  }
  .cover-wrap :global(img) {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    border: 1px solid var(--line);
  }
  .body-wrap {
    margin-top: var(--section-y);
  }
  .gallery-wrap {
    margin-top: var(--section-y);
  }
  .related h2 {
    margin-bottom: var(--gap);
  }
</style>
